# 北森系统地址（示例：https://yourcompany.beisen.com）
BEISEN_BASE_URL=https://yourcompany.beisen.com

# 登录账号
BEISEN_USERNAME=your_username
BEISEN_PASSWORD=your_password

# 候选人列表页路径（相对 base_url）
BEISEN_CANDIDATE_LIST_PATH=/recruit/candidate/list

# 浏览器数据持久化目录（保存 cookie，避免重复登录）
BROWSER_DATA_DIR=./browser-data

# 单步操作超时（毫秒）
TIMEOUT=15000

# 候选人列表每页数量（通常为 15）
CANDIDATES_PER_PAGE=15
